# -----------------------------------------------------------------------------
*.log
logs/
apps/api/logs/

# -----------------------------------------------------------------------------
# Environment / Secrets – NEVER commit
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
apps/api/.env
apps/web/.env
apps/web/.env.local
apps/web/.env.production
apps/web/.env.production.local
apps/web/.env.development.local
apps/web/.env.test.local
