# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# Package managers
.pdm.toml
.pdm-python
.pdm-build/
__pypackages__/
Pipfile.lock

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
